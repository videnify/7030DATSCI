# ============================================================
# DATSCI7030 — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# --- Virtual environments ---

# --- Local caches (e.g. yfinance sqlite cache) ---
.cache/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Data (raw/interim/processed/external data itself is never committed) ---
# Pattern ignores directory CONTENTS (folder/*) rather than the folder itself,
# so README.md / .gitkeep can be negated back in to preserve structure on a fresh clone.
data/raw/*
!data/raw/README.md
!data/raw/.gitkeep

data/processed/*
!data/processed/README.md
!data/processed/.gitkeep

data/interim/*

!data/interim/README.md
!data/interim/.gitkeep

data/external/*
!data/external/README.md
!data/external/.gitkeep

# Research Bible governance, contracts, decisions, and traceability are source
# documentation and must remain version-controlled with the pipeline.

# Belt-and-braces: never allow these extensions anywhere in the repo
*.csv
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.xlsx
*.xls
*.docx
*.doc

# --- Models (trained binaries — never committed, only the code that produces them) ---
models/*
!models/README.md
!models/.gitkeep
*.pt
*.pth
*.onnx
*.joblib

# --- Notebook archive (superseded/duplicate notebooks — kept locally for reference only) ---
notebooks/archive/

# --- Environment variables & secrets ---
.env
*.env
.env.*
!.env.example
config.yaml
*.key
*.pem
*_secret*
*_private*
*credentials*

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Office lock/temp files (e.g. ~$thesis.docx while a .docx is open) ---
~$*
*.tmp

# --- IDEs ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- Reports (generated/duplicate exports — the dissertation itself is tracked separately) ---
reports/**/archive/
reports/figures/*.pdf
reports/figures/*.html
reports/figures/*.svg
# Recursive (not just top-level reports/*) so reports/dissertation/*.pdf and
# reports/stakeholder/*.pdf are also excluded — .docx is additionally covered
# globally by the belt-and-braces *.docx rule above.
reports/**/*.docx
reports/**/*.pdf

# --- Logs ---
logs/*
!logs/README.md
!logs/.gitkeep
*.log
